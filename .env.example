# Copy to .env and fill in once your hackathon access opens (10:30am PT).
# Get your key + Org ID at https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Optional: for the side-by-side latency comparison in the demo video.
GEMINI_API_KEY=

# Set to 1 to force mock mode (develop the whole pipeline before API access).
# Leave unset/0 once you have a real key — the client auto-mocks if no key is present.
GEMMA_MOCK=
