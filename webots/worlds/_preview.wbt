#VRML_SIM R2025a utf8
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/humans/pedestrian/protos/Pedestrian.proto"
WorldInfo { basicTimeStep 16 }
Viewpoint { orientation 0 0 1 0 position 0 0 40 }
Background { skyColor [ 0.45 0.65 0.92 ] }
TexturedBackgroundLight { luminosity 1.1 }
DirectionalLight { ambientIntensity 0.6 color 1 1 1 direction 0.3 0.3 -1 intensity 1.5 castShadows FALSE }
DEF CITY Solid { children [ CadShape { url [ "../assets/citymesh/city_fixed.obj" ] } ] name "c" }
DEF CA Solid { translation -156 163 0 rotation 0 0 1 0.35 children [ CadShape { url [ "../assets/crashmodel/crash.obj" ] } ] name "ca" }
DEF CB Solid { translation -151.5 166.5 0 rotation 0 0 1 2.1 children [ CadShape { url [ "../assets/crashmodel/crash.obj" ] } ] name "cb" }
DEF V1 Pedestrian { translation -155.8 165.8 0.35 rotation 1 0 0 1.5708 name "v1" controller "<none>" }
DEF SHOT Robot { translation -154 164 26 rotation 0 1 0 1.5708 children [ Camera { name "camera" width 800 height 800 fieldOfView 1.0 near 0.1 } ] name "shot" controller "preview_cap" supervisor TRUE }
